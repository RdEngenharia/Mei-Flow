rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -----------------------------------------------------------------
    // 1. ÁREA DO PERFIL DO USUÁRIO (Protegida contra Auto-Upgrade de Plano)
    // -----------------------------------------------------------------
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Impede auto-promoção ao criar o documento
      allow create: if request.auth != null && request.auth.uid == userId && 
        (!request.resource.data.keys().hasAny(['planType', 'plan', 'isPremium']) || request.resource.data.planType == 'free');
      
      // Impede modificação de campos de assinatura e faturamento no update pelo SDK Client
      allow update: if request.auth != null && request.auth.uid == userId && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['planType', 'plan', 'isPremium', 'status', 'mercadoPagoStatus', 'mercadoPagoPaymentId']);
        
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // Permite que o usuário gerencie seu próprio catálogo de produtos/serviços
      match /catalog/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Permite que o usuário gerencie seus documentos no Arquivo Digital
      match /documentos/{documentId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Mantém o acesso para qualquer outra subcoleção futura
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Compatibilidade com coleção legada de usuários sincronizada pelo backend
    match /usuarios/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Impede auto-promoção ao criar o documento legado
      allow create: if request.auth != null && request.auth.uid == userId && 
        (!request.resource.data.keys().hasAny(['planType', 'plan', 'isPremium']) || request.resource.data.planType == 'free');
      
      // Impede modificação de campos de assinatura no update legado pelo SDK Client
      allow update: if request.auth != null && request.auth.uid == userId && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['planType', 'plan', 'isPremium', 'status', 'mercadoPagoStatus', 'mercadoPagoPaymentId']);
        
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // -----------------------------------------------------------------
    // 2. PARCEIROS COMERCIAIS & CLIENTES (Necessário para a tela de Clientes)
    // -----------------------------------------------------------------
    match /customers/{customerId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow get: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    match /clientes/{clienteId} {
      allow create: if request.auth != null && request.resource.data.mei_uid == request.auth.uid;
      allow get: if request.auth != null && (resource == null || resource.data.mei_uid == request.auth.uid);
      allow list: if request.auth != null && resource.data.mei_uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.mei_uid == request.auth.uid;
    }

    // -----------------------------------------------------------------
    // 3. ENTRADAS & MOVIMENTAÇÕES (Necessário para a tela de Extrato/Transações e o Asaas)
    // -----------------------------------------------------------------
    match /transactions/{transactionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow get: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /transacoes/{transacaoId} {
      allow create: if request.auth != null && request.resource.data.mei_uid == request.auth.uid;
      allow get: if request.auth != null && (resource == null || resource.data.mei_uid == request.auth.uid);
      allow list: if request.auth != null && resource.data.mei_uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.mei_uid == request.auth.uid;
    }

    // -----------------------------------------------------------------
    // 4. ARQUIVO DIGITAL DO MEI (Metadados dos documentos e comprovantes)
    // -----------------------------------------------------------------
    match /documentos_mei/{documentId} {
      allow read, write: if request.auth != null;
    }
  }
}
