rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /vendas/{vendaId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    match /customers/{customerId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }
    match /clientes/{clienteId} {
      allow create: if request.auth != null && request.resource.data.mei_uid == request.auth.uid;
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.mei_uid == request.auth.uid);
    }
    match /transactions/{transactionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }
    match /transacoes/{transacaoId} {
      allow create: if request.auth != null && request.resource.data.mei_uid == request.auth.uid;
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.mei_uid == request.auth.uid);
    }
  }
}
