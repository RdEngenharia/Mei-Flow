{
  "entities": {
    "users": {
      "title": "users",
      "description": "Perfis MEI de Microempreendedor Individual",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID exclusivo de autenticação do usuário MEI" },
        "name": { "type": "string", "description": "Nome fantasia ou oficial do MEI" },
        "email": { "type": "string", "description": "E-mail cadastrado" },
        "planType": { "type": "string", "description": "Plano contratado pelo usuário ('free' ou 'premium')" },
        "logoUrl": { "type": "string", "description": "Logotipo personalizado" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Data de cadastramento" }
      },
      "required": ["uid", "name", "email", "planType"]
    },
    "customers": {
      "title": "customers",
      "description": "Clientes associados ao MEI para fins de faturamento e Notas Fiscais",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID exclusivo do cliente" },
        "userId": { "type": "string", "description": "ID do usuário MEI proprietário do cliente" },
        "name": { "type": "string", "description": "Nome ou Razão Social do cliente" },
        "cpfCnpj": { "type": "string", "description": "CPF ou CNPJ do cliente" },
        "email": { "type": "string", "description": "E-mail de contato" },
        "telefone": { "type": "string", "description": "Telefone de contato" },
        "createdAt": { "type": "string", "description": "Data de cadastramento" }
      },
      "required": ["id", "userId", "name"]
    },
    "transactions": {
      "title": "transactions",
      "description": "Registros fiscais e movimentações financeiras de entradas (vendas) e saídas (despesas)",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID exclusivo da transação" },
        "userId": { "type": "string", "description": "ID do usuário MEI proprietário do lançamento" },
        "type": { "type": "string", "enum": ["entrada", "saida"], "description": "Tipo de movimentação" },
        "value": { "type": "number", "description": "Valor monetário bruto em Reais" },
        "description": { "type": "string", "description": "Histórico ou descrição do serviço/despesa" },
        "date": { "type": "string", "description": "Data de faturamento" },
        "categoria": { "type": "string", "description": "Categoria fiscal para fins de livro caixa" },
        "clienteId": { "type": "string", "description": "ID do cliente tomador associado" },
        "clienteNome": { "type": "string", "description": "Nome do cliente denormalizado no lançamento" },
        "clienteDocumento": { "type": "string", "description": "CNPJ/CPF do cliente denormalizado" }
      },
      "required": ["id", "userId", "type", "value", "date", "description"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Dados do perfil MEI autenticado"
    },
    "/customers/{customerId}": {
      "schema": "customers",
      "description": "Clientes associados ao MEI autenticado"
    },
    "/transactions/{transactionId}": {
      "schema": "transactions",
      "description": "Movimentações de entradas e saídas fiscais do MEI autenticado"
    },
    "/usuarios/{userId}": {
      "schema": "users",
      "description": "Dados do perfil MEI autenticado (alternativo)"
    },
    "/usuarios/{userId}/vendas/{vendaId}": {
      "schema": "transactions",
      "description": "Vendas do usuário MEI na subcoleção do usuário"
    }
  }
}
